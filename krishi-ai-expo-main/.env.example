# ─── Krishi AI Expo – Environment Variables ───────────────────────────────────
# Copy to .env and fill in real values.
# In Expo, client-side variables MUST start with EXPO_PUBLIC_

# Google Gemini API (required for AI features)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional – for cloud sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_anon_key_here

# Hugging Face (optional – for HF ML models)
EXPO_PUBLIC_HF_TOKEN=your_huggingface_token_here
